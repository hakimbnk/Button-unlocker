{
  "manifest_version": 3,
  "name": "Button Unlocker",
  "version": "2.0",
  "description": "Débloque le bouton d'envoi sur Claude, ChatGPT, Gemini, Perplexity et plus",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://mistral.ai/*",
    "https://chat.mistral.ai/*",
    "https://huggingface.co/*",
    "https://poe.com/*",
    "https://you.com/*",
    "https://copilot.microsoft.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://mistral.ai/*",
        "https://chat.mistral.ai/*",
        "https://huggingface.co/*",
        "https://poe.com/*",
        "https://you.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
